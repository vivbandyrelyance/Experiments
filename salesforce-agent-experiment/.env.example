# Copy this file to .env and fill in your values
# .env is git-ignored — never commit the real file

# Salesforce credentials (get security token from: Settings > Personal > Reset My Security Token)
SALESFORCE_USERNAME=you@yourdevorg.com
SALESFORCE_PASSWORD=yourpassword
SALESFORCE_SECURITY_TOKEN=yourtoken

# "login" for Developer Edition / production, "test" for sandboxes
SALESFORCE_DOMAIN=login

# Salesforce API version (62.0 = Winter '25, safe default)
SALESFORCE_API_VERSION=62.0

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
